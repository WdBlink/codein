{
	"name": "obsidian-plugin-codeian",
	"version": "0.2.9",
	"description": "Use Codex from a sidebar in your vault.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"lint": "eslint .",
		"test": "vitest run",
		"verify:release": "node scripts/verify-release-files.mjs",
		"smoke:test-vault": "node scripts/smoke-test-vault.mjs"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"codex",
		"codex-cli"
	],
	"author": "echooo",
	"license": "MIT",
	"engines": {
		"node": ">=20.19.0"
	},
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^20.19.0",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "3.2.4"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
